# ── PAAI Environment Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask
SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_ENV=development
FLASK_APP=main.py

# ── DATABASE ────────────────────────────────────────────────────────────────
# OPTION A: Leave blank to use SQLite (easiest for local dev on Windows)
DATABASE_URL=

# OPTION B: PostgreSQL (recommended for production)
# pg8000 driver is used automatically — no compilation needed.
# DATABASE_URL=postgresql://paai_user:paai_pass@localhost:5432/paai_db

# OPTION C: Neon / Supabase / Railway cloud PostgreSQL (free tiers)
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname

# ── EMAIL (optional for dev) ────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ── AI CHATBOT (optional) ───────────────────────────────────────────────────
# Leave blank to use the built-in rule-based chatbot
OPENAI_API_KEY=
